VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_LOCAL_APP_URL=http://localhost:9000
VITE_PRODUCTION_APP_URL=https://your-pages-domain.pages.dev
CF_PAGES_PROJECT_NAME=your_cloudflare_pages_project

# Python PC export
PY_SUPABASE_STORAGE_BUCKET=product-images
PY_SUPABASE_STORAGE_PREFIX=uk/pc

# Python -> Supabase products sync (used by `npm run python:pc`)
SUPABASE_SECRET_KEY=your_supabase_secret_key
# Legacy fallback only:
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Optional sync scope overrides
# PY_PRODUCTS_VENDOR_CODE=PC
# PY_PRODUCTS_MARKET_CODE=GB
# PY_PRODUCTS_TENANT_ID=
# PY_PRODUCTS_SYNC_CHUNK_SIZE=250
# Optional overrides
# PY_UK_PC_XLSX_PATH=python/data/uk/pc_data.xlsx
# PY_UK_PC_OUT_JSON_PATH=web/public/uk/pc_data.json
# PY_UK_PC_OUT_MANIFEST_PATH=web/public/uk/pc_manifest.json
# PY_UK_PC_OUT_IMAGES_DIR=python/images/uk/out_images
