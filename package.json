{
  "name": "brandwala-wholesale-quasar-root",
  "private": true,
  "version": "1.0.0",
  "description": "Root scripts for web app and Supabase backend",
  "scripts": {
    "dev": "npm --prefix web run dev",
    "build": "npm --prefix web run build",
    "lint": "npm --prefix web run lint",
    "python:pc": "bash scripts/run-python-pc.sh",
    "python:wts": "bash scripts/run-python-wts.sh",
    "python:scrape:pc": "bash -c 'cd python && source ../.venv/bin/activate && python3 scripts/uk/export_pricecheck_scraper.py'",
    "python:sync:scraped-pc": "bash -c 'cd python && source ../.venv/bin/activate && python3 scripts/uk/sync_scraped_pc_to_supabase.py'",
    "python:koba-retail": "bash scripts/run-python-koba-retail.sh",
    "python:koba-wholesale": "bash scripts/run-python-koba-wholesale.sh",
    "python:normalize:pc": "python3 python/scripts/uk/normalize_pc_data.py --input web/public/uk/pc_data.json",
    "python:taxonomy:pc": "python3 python/scripts/uk/export_pc_taxonomy.py --input web/public/uk/pc_data.json",
    "python:clean:vat-names": "python3 python/scripts/uk/remove_vat_from_names.py --input web/public/uk/pc_data.json",
    "python:clean:ml-names": "python3 python/scripts/uk/move_ml_to_end.py --input web/public/uk/pc_data.json --fields name",
    "python:sync:pc": "python3 python/scripts/uk/sync_pc_products_to_supabase.py --input web/public/uk/pc_data.json --vendor PC --market GB",
    "python:sync:wts": "python3 python/scripts/uk/sync_pc_products_to_supabase.py --input web/public/uk/wts_data.json --vendor WTS --market GB --tenant-id 10 --vendor-id 4 --images-dir python/images/uk/wts_images --skip-image-upload",
    "deploy:frontend": "bash scripts/deploy-frontend.sh",
    "secrets:drive": "bash scripts/set-drive-secrets.sh",
    "secrets:drive-oauth": "bash scripts/set-drive-oauth-secrets.sh",
    "backend:init": "npx supabase init",
    "backend:login": "npx supabase login",
    "backend:link": "npx supabase link --project-ref \"$SUPABASE_PROJECT_REF\"",
    "backend:link:push:types": "sh -c 'npm run backend:link && npx supabase db push --linked --include-all && mkdir -p web/src/types && npx supabase gen types typescript --linked --schema public > web/src/types/supabase.ts'",
    "backend:new-migration": "npx supabase migration new",
    "backend:push": "npx supabase db push --linked",
    "backend:push:all": "npx supabase db push --linked --include-all",
    "backend:types": "sh -c 'mkdir -p web/src/types && npx supabase gen types typescript --linked --schema public > web/src/types/supabase.ts'",
    "deploy:backend": "npm run backend:push && npm run backend:types",
    "backend:all": "npm run backend:push:all && npm run backend:types"
  },
  "devDependencies": {
    "supabase": "^2.105.0",
    "wrangler": "^4.93.1"
  }
}
